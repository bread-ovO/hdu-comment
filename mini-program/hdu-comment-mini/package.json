    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "babel-preset-taro": "^4.1.11",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.0",
    "react-refresh": "^0.18.0",
    "typescript": "^5.3.3"
